{
  "name": "assay",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm build && pnpm typecheck && pnpm lint && pnpm test && pnpm smoke",
    "format": "biome format --write .",
    "lint": "biome check .",
    "smoke": "node scripts/cli-smoke.mjs",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
