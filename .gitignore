# Virtual environments
.venv/
venv/
.env
.env.*
!.env.example

# Packaging/build output
build/
dist/
node_modules/
coverage/
*.tgz
*.tar.gz

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Framework runtime/private material
**/.framework/backups/*
!**/.framework/backups/.gitkeep
**/.framework/events/*
!**/.framework/events/.gitkeep
**/.framework/.runtime/
# ADRs and framework self-governance decisions are local artifacts, not version-controlled
**/.framework/decisions/
**/references/frozen/*
!**/references/frozen/README.md

# Local sidecar names, if copied into the repo by mistake
metasystem_kit_private_materials/
_private/
